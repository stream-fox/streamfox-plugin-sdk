    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9",
    "@types/prompts": "^2.4.9"
  }
